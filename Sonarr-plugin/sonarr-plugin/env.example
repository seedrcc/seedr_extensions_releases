# Sonarr-Seedr Configuration
# Copy this file to .env and fill in your actual values

# Seedr Configuration
# Get your Client ID from: https://www.seedr.cc/api
SEEDR_CLIENT_ID=your_seedr_client_id_here
SEEDR_API_BASE_URL=https://v2.seedr.cc

# Sonarr Configuration  
SONARR_HOST=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key_here

# Download Configuration
DOWNLOAD_DIR=C:\Downloads\Sonarr
ROOT_FOLDER=C:\Downloads\Sonarr

# Instructions:
# 1. Rename this file from env.example to .env
# 2. Replace the placeholder values with your actual configuration
# 3. Place this .env file in the same directory as SonarrSeedr.exe
# 4. Restart the application
