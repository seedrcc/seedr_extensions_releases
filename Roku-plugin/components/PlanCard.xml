<?xml version="1.0" encoding="UTF-8"?>

<component name="PlanCard" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/PlanCard.brs" />
    
    <interface>
        <!-- Input fields -->
        <field id="planData" type="assocarray" onChange="onPlanDataChanged" />
        <field id="isAnnual" type="boolean" value="false" />
        <field id="isFocused" type="boolean" value="false" onChange="onFocusChanged" />
        
        <!-- Output fields -->
        <field id="itemSelected" type="boolean" alwaysNotify="true" />
    </interface>
    
    <children>
        <!-- Main card container -->
        <Rectangle
            id="cardContainer"
            width="380"
            height="620"
            color="0xFFFFFFFF"
            opacity="1.0">
            
            <!-- Card border (will change color based on plan) -->
            <Rectangle
                id="cardBorder"
                width="380"
                height="620"
                color="0xFF6B35FF"
                opacity="0.0">
                <Rectangle
                    translation="[6, 6]"
                    width="368"
                    height="608"
                    color="0xFFFFFFFF" />
            </Rectangle>
            
            <!-- Focus indicator border (thicker when focused) -->
            <Rectangle
                id="focusBorder"
                width="380"
                height="620"
                color="0xFFFFFFFF"
                opacity="0.0">
                <Rectangle
                    translation="[8, 8]"
                    width="364"
                    height="604"
                    color="0xFFFFFFFF" />
            </Rectangle>
        </Rectangle>
        
        <!-- Top badge for "Most Popular" -->
        <Rectangle
            id="topBadge"
            translation="[0, -40]"
            width="380"
            height="80"
            color="0x4CAF50FF"
            visible="false">
            <Label
                id="topBadgeText"
                translation="[0, 0]"
                width="380"
                height="80"
                text="Most Popular"
                font="font:MediumBoldSystemFont"
                color="0xFFFFFFFF"
                horizAlign="center"
                vertAlign="center" />
            <!-- Rounded top corners effect -->
            <Rectangle
                translation="[0, 0]"
                width="20"
                height="20"
                color="0x000000FF"
                opacity="0.0" />
        </Rectangle>
        
        <!-- Plan icon -->
        <Poster
            id="planIcon"
            translation="[140, 50]"
            width="100"
            height="100"
            loadDisplayMode="scaleToFit"
            failedBitmapUri="pkg:/images/plan_basic_logo_SVG.png" />
        
        <!-- Plan name -->
        <Label
            id="planName"
            translation="[40, 170]"
            width="300"
            height="50"
            text="Basic"
            font="font:LargeBoldSystemFont"
            color="0xFF6B35FF"
            horizAlign="center"
            vertAlign="center" />
        
        <!-- Price -->
        <Label
            id="priceLabel"
            translation="[40, 220]"
            width="300"
            height="70"
            text="$6.95"
            font="font:VeryLargeBoldSystemFont"
            color="0x333333FF"
            horizAlign="center"
            vertAlign="center" />
        
        <!-- Buy Now Button -->
        <Rectangle
            id="buyButton"
            translation="[90, 310]"
            width="200"
            height="60"
            color="0xFF6B35FF">
            <Label
                id="buyButtonText"
                translation="[0, 0]"
                width="200"
                height="60"
                text="Buy Now"
                font="font:MediumBoldSystemFont"
                color="0xFFFFFFFF"
                horizAlign="center"
                vertAlign="center" />
        </Rectangle>
        
        <!-- Annual savings text -->
        <Label
            id="annualText"
            translation="[40, 390]"
            width="300"
            height="40"
            text="Subscribe Annually and get"
            font="font:SmallSystemFont"
            color="0x666666FF"
            horizAlign="center"
            vertAlign="center"
            wrap="true" />
        
        <Label
            id="annualText2"
            translation="[40, 425]"
            width="300"
            height="35"
            text="2 months free"
            font="font:SmallSystemFont"
            color="0x666666FF"
            horizAlign="center"
            vertAlign="center" />
        
        <!-- Savings amount -->
        <Label
            id="savingsLabel"
            translation="[40, 465]"
            width="300"
            height="40"
            text="Save $13.9"
            font="font:MediumBoldSystemFont"
            color="0x333333FF"
            horizAlign="center"
            vertAlign="center" />
        
        <!-- Feature description -->
        <Label
            id="featureDescription"
            translation="[40, 520]"
            width="300"
            height="80"
            text="Transfer faster. HD playback. Suitable for casual users"
            font="font:SmallSystemFont"
            color="0x666666FF"
            horizAlign="center"
            vertAlign="center"
            wrap="true" />
    </children>
</component>


