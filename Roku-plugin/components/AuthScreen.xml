<?xml version="1.0" encoding="UTF-8"?>
<!--********** seedr-Style Authentication Screen for Roku **********-->

<component name="AuthScreen" extends="Group" focusable="true">
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/api.brs" />
    <script type="text/brightscript" uri="pkg:/source/auth.brs" />
    <script type="text/brightscript" uri="AuthScreen.brs" />
    
    <interface>
        <field id="authCheck" type="integer" />
        <field id="showDeviceAuth" type="boolean" alwaysNotify="true" />
    </interface>
    
    <children>
        <!-- Dark cinematic background with gradient overlay -->
        <Rectangle id="background" width="1920" height="1080" color="0x000000FF" />
        
        <!-- Background image with dark movie scene effect -->
        <Poster id="backgroundImage" 
                uri="pkg:/images/splash_hd.jpg" 
                width="1920" 
                height="1080" 
                loadDisplayMode="scaleToFill" />
        
        <!-- Multiple gradient overlays for depth and card visibility -->
        <Rectangle width="1920" height="1080" color="0x000000CC" opacity="0.8" />
        <Rectangle width="960" height="1080" color="0x000000AA" opacity="0.6" translation="[960, 0]" />
        <Rectangle width="480" height="1080" color="0x00000066" opacity="0.4" translation="[1440, 0]" />
        
        <!-- seedr Logo (top left with better positioning) -->
        <Label text="SEEDR" 
               font="font:LargeBoldSystemFont" 
               color="0x8A0194" 
               translation="[80, 50]" 
               horizAlign="left" />
        
        <!-- Feature Image on the left side -->
        <Poster id="featureImage" 
                uri="pkg:/images/home_feature.png" 
                width="620" 
                height="480" 
                translation="[50, 150]"
                loadDisplayMode="scaleToFit" />
        
        <!-- Main Authentication Card (positioned to the right of feature image) -->
        <Group id="mainCard" visible="true" translation="[720, 240]" focusable="true">
            
            <!-- Card background with rounded corners effect using multiple layers -->
            <Rectangle width="480" height="420" color="0x000000F0" translation="[-4, -4]" opacity="0.3" />
            <Rectangle width="472" height="412" color="0x1a1a1aF5" translation="[0, 0]" opacity="0.95" />
            <Rectangle width="468" height="408" color="0x2d2d3aF0" translation="[2, 2]" />
            
            <!-- Inner content container with padding -->
            <Group id="contentContainer" translation="[40, 50]">
                
                <!-- Main heading with seedr typography -->
                <Label id="mainHeading" 
                       text="Join today for endless entertainment" 
                       font="font:LargeBoldSystemFont" 
                       color="0xFFFFFFFF" 
                       translation="[0, 0]" 
                       width="390"
                       wrap="true"
                       lineSpacing="1.1" />
                
                <!-- Feature list with styled checkmarks -->
                <Group id="featureList" translation="[0, 80]">
                    
                    <!-- Feature 1 with checkmark -->
                    <Group translation="[0, 0]">
                        <Label text="✓" 
                               font="font:MediumBoldSystemFont" 
                               color="0xE12AFB" 
                               translation="[0, 2]" />
                        <Label text="Plans start at just $3.99" 
                               font="font:MediumSystemFont" 
                               color="0xCCCCCCFF" 
                               translation="[30, 0]" />
                    </Group>
                    
                    <!-- Feature 2 with checkmark -->
                    <Group translation="[0, 40]">
                        <Label text="✓" 
                               font="font:MediumBoldSystemFont" 
                               color="0xE12AFB" 
                               translation="[0, 2]" />
                        <Label text="New exclusives, shows and" 
                               font="font:MediumSystemFont" 
                               color="0xCCCCCCFF" 
                               translation="[30, 0]" />
                        <Label text="movies every week" 
                               font="font:MediumSystemFont" 
                               color="0xCCCCCCFF" 
                               translation="[30, 25]" />
                    </Group>
                    
                    <!-- Feature 3 with checkmark -->
                    <Group translation="[0, 105]">
                        <Label text="✓" 
                               font="font:MediumBoldSystemFont" 
                               color="0xE12AFB" 
                               translation="[0, 2]" />
                        <Label text="Cancel anytime" 
                               font="font:MediumSystemFont" 
                               color="0xCCCCCCFF" 
                               translation="[30, 0]" />
                    </Group>
                </Group>
                
                <!-- Bottom section with Get Help and Sign In button -->
                <Group id="bottomSection" translation="[0, 240]">
                    
                    <!-- Get Help link with underline effect -->
                    <Group id="getHelpGroup" translation="[0, 0]">
                        <Label text="Get Help" 
                               font="font:MediumSystemFont" 
                               color="0x999999FF" 
                               translation="[0, 0]" />
                        <Rectangle id="helpUnderline" 
                                   width="70" 
                                   height="1" 
                                   color="0x999999FF" 
                                   translation="[0, 25]" 
                                   visible="false" />
                    </Group>
                    
                    <!-- Sign In button with seedr red styling -->
                    <Group id="signInButton" translation="[120, -5]" focusable="true">
                        <!-- Button shadow for depth -->
                        <Rectangle width="200" height="50" 
                                   color="0x000000FF" 
                                   translation="[2, 2]" 
                                   opacity="0.3" />
                        
                        <!-- Main button background -->
                        <Rectangle id="signInBg" 
                                   width="200" 
                                   height="50" 
                                   color="0xA813B7" />
                        
                        <!-- Button text centered -->
                        <Label text="Sign In" 
                               font="font:MediumBoldSystemFont" 
                               color="0xFFFFFFFF" 
                               translation="[0, 0]" 
                               width="200"
                               height="50"
                               horizAlign="center"
                               vertAlign="center" />
                        
                        <!-- Focus border (hidden by default) -->
                        <Rectangle id="focusBorder" 
                                   width="204" 
                                   height="54" 
                                   color="0xFFFFFFFF" 
                                   translation="[-2, -2]" 
                                   opacity="0" />
                    </Group>
                </Group>
            </Group>
        </Group>
        
        <!-- Optional: Animated elements for visual appeal -->
        <Group id="animatedElements">
            <!-- Subtle glow effect behind card -->
            <Rectangle id="cardGlow" 
                       width="520" 
                       height="460" 
                       color="0xE5091411" 
                       translation="[700, 220]" 
                       opacity="0.2" />
        </Group>
    </children>
</component>