<?xml version="1.0" encoding="utf-8" ?>
<component name="ImageViewer" extends="Group">
    <interface>
        <field id="imageData" type="assocarray" alwaysnotify="true" />
        <field id="onBackPressed" type="boolean" value="false" />
    </interface>

    <script type="text/brightscript" uri="ImageViewer.brs" />

    <children>
        <!-- Background -->
        <Rectangle 
            id="background"
            color="0x000000FF"
            width="1280"
            height="720" />

        <!-- Loading indicator -->
        <Label
            id="loadingLabel"
            text="Loading image..."
            translation="[640, 360]"
            horizAlign="center"
            vertAlign="center"
            color="0xFFFFFFFF"
            font="font:MediumSystemFont"
            visible="true" />

        <!-- Main image -->
        <Poster
            id="mainImage"
            translation="[0, 0]"
            width="1280"
            height="720"
            scaleRotateCenter="[640, 360]"
            visible="false" />

        <!-- Info overlay -->
        <Group id="infoOverlay" translation="[20, 20]" visible="true">
            <Rectangle 
                id="infoBackground"
                color="0x000000AA"
                width="600"
                height="120" />
            
            <Label
                id="imageTitle"
                text=""
                translation="[20, 20]"
                color="0xFFFFFFFF"
                font="font:LargeSystemFont"
                width="560" />
            
            <Label
                id="imageInfo"
                text=""
                translation="[20, 60]"
                color="0xCCCCCCFF"
                font="font:MediumSystemFont"
                width="560" />
            
            <Label
                id="controlsHint"
                text="Back: Return • OK: Toggle Info"
                translation="[20, 90]"
                color="0x00ADEFFF"
                font="font:SmallSystemFont"
                width="560" />
        </Group>

        <!-- Error message -->
        <Group id="errorGroup" translation="[640, 360]" visible="false">
            <Rectangle 
                id="errorBackground"
                color="0x800000FF"
                width="400"
                height="150"
                translation="[-200, -75]" />
            
            <Label
                id="errorTitle"
                text="Error"
                translation="[0, -40]"
                horizAlign="center"
                color="0xFFFFFFFF"
                font="font:LargeSystemFont" />
            
            <Label
                id="errorMessage"
                text=""
                translation="[0, 0]"
                horizAlign="center"
                color="0xFFFFFFFF"
                font="font:MediumSystemFont"
                width="380" />
            
            <Label
                id="errorHint"
                text="Press Back to return"
                translation="[0, 40]"
                horizAlign="center"
                color="0xCCCCCCFF"
                font="font:SmallSystemFont" />
        </Group>
    </children>
</component>
