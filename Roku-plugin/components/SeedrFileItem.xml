<?xml version="1.0" encoding="utf-8"?>

<component name="SeedrFileItem" extends="Group">
  <script type="text/brightscript" uri="SeedrFileItem.brs"/>
  <interface>
    <field id="itemContent" type="node" onChange="showcontent"/>
    <field id="focusPercent" type="float" onChange="onFocusPercentChange"/>
  </interface>

  <children>
    <!-- Regular File Item (default) -->
    <Group id="regularItem" visible="true">
      <Poster 
        id="itemPoster"  
        width="300" 
        height="160"
        loadDisplayMode="scaleToFit"
        failedBitmapUri="pkg:/images/icon_focus_hd.png">
      </Poster>

      <Label 
        id="itemLabel" 
        horizAlign="left" 
        vertAlign="bottom"
        width="300" 
        height="200"
        font="font:SmallSystemFont"
        color="0xFFFFFF" />
    </Group>
    
    <!-- Video Item (for video files) -->
    <VideoItem id="videoItem" visible="false" />
  </children>

</component>
