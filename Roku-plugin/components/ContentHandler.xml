<?xml version="1.0" encoding="utf-8" ?>
<!-- Content Handler Component for Seedr API -->

<component name="ContentHandler" extends="Task">

  <interface>
    <!-- Input fields -->
    <field id="accessToken" type="string" />
    <field id="folderId" type="string" value="" />
    
    <!-- Output fields -->
    <field id="content" type="node" />
    <field id="numBadRequests" type="integer" value="0" />
    
    <!-- Control field -->
    <field id="control" type="string" />
  </interface>

  <script type="text/brightscript" uri="ContentHandler.brs" />

</component>
