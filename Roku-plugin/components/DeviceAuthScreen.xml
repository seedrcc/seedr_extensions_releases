<?xml version="1.0" encoding="UTF-8"?>
<!--********** Modern Device Authorization Screen - Spotify Style **********-->

<component name="DeviceAuthScreen" extends="Group">
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/api.brs" />
    <script type="text/brightscript" uri="pkg:/source/auth.brs" />
    <script type="text/brightscript" uri="DeviceAuthScreen.brs" />
    
    <interface>
        <field id="authComplete" type="boolean" />
        <field id="backPressed" type="boolean" alwaysNotify="true" />
    </interface>
    
    <children>
        <!-- Dark background -->
        <Rectangle id="background" width="1920" height="1080" color="0x121212FF" />
        
        <!-- Subtle gradient overlay -->
        <Rectangle width="1920" height="1080" color="0x000000FF" opacity="0.4" />
        
        <!-- SEEDR Logo (top left) -->
        <Label text="SEEDR" 
               font="font:LargeBoldSystemFont" 
               color="0x1DB954FF" 
               translation="[80, 50]" 
               horizAlign="left" />
        
        <!-- Main Authorization Container -->
        <Group id="mainAuthContainer" visible="true" translation="[0, 0]">
            
            <!-- Loading State (Initially visible) -->
            <Group id="loadingState" visible="false" translation="[0, 0]">
                <Rectangle width="400" height="100" color="0x1a1a1aFF" translation="[-200, -50]" opacity="0.9" />
                
                <Label text="Setting up authentication..." 
                       font="font:MediumSystemFont" 
                       color="0xFFFFFFFF" 
                       translation="[0, 0]" 
                       horizAlign="center" />
                
                <!-- Loading spinner placeholder -->
                <Rectangle id="spinner" width="30" height="30" color="0x1DB954FF" translation="[-15, 30]" opacity="0.8" />
            </Group>
            
            <!-- Main Auth Options (visible after loading) -->
            <Group id="authOptionsContainer" visible="true" translation="[50, 120]">
                
                <!-- Option 1: QR Code Section -->
                <Group id="qrSection" translation="[0, 0]">
                    <!-- Option header -->
                    <Label text="Option 1" 
                           font="font:SmallSystemFont" 
                           color="0x888888FF" 
                           translation="[0, -40]" />
                    
                    <Label text="Scan this QR code" 
                           font="font:LargeBoldSystemFont" 
                           color="0xFFFFFFFF" 
                           translation="[0, 0]" />
                    
                    <!-- QR Code Container -->
                    <Rectangle width="240" height="240" color="0xFFFFFFFF" translation="[0, 40]">
                        <!-- Actual QR Code Image -->
                        <Poster id="qrCodeImage" 
                                width="220" 
                                height="220" 
                                translation="[10, 10]"
                                loadDisplayMode="scaleToFit"
                                failedBitmapUri=""
                                visible="false" />
                        
                        <!-- Loading/Fallback QR text placeholder -->
                        <Label id="qrCodeText" 
                               text="Loading QR..." 
                               font="font:MediumBoldSystemFont" 
                               color="0x333333FF" 
                               translation="[120, 120]" 
                               horizAlign="center" 
                               vertAlign="center" />
                    </Rectangle>
                    
                   
                    
                    <!-- QR Instructions -->
                    <Label text="On your mobile phone, open" 
                           font="font:SmallSystemFont" 
                           color="0xCCCCCCFF" 
                           translation="[0, 300]" 
                           width="300" />
                    
                    <Label text="the camera and point to this" 
                           font="font:SmallSystemFont" 
                           color="0xCCCCCCFF" 
                           translation="[0, 325]" 
                           width="300" />
                    
                    <Label text="QR code to scan." 
                           font="font:SmallSystemFont" 
                           color="0xCCCCCCFF" 
                           translation="[0, 350]" 
                           width="240" />
                </Group>
                
                <!-- Divider -->
                <Rectangle width="1" height="320" color="0x333333FF" translation="[360, 40]" />
                
                <!-- Option 2: Web Page Section -->
                <Group id="webSection" translation="[500, 0]">
                    <!-- Option header -->
                    <Label text="Option 2" 
                           font="font:SmallSystemFont" 
                           color="0x888888FF" 
                           translation="[0, -40]" />
                    
                    <Label text="Use a webpage" 
                           font="font:LargeBoldSystemFont" 
                           color="0xFFFFFFFF" 
                           translation="[0, 0]" />
                    
                    <!-- Step 1: URL -->
                    <Label text="1. On your mobile phone or computer," 
                           font="font:SmallSystemFont" 
                           color="0xCCCCCCFF" 
                           translation="[0, 50]" 
                           width="450" 
                           wrap="true" />
                    
                    <Label text="type the address below:" 
                           font="font:SmallSystemFont" 
                           color="0xCCCCCCFF" 
                           translation="[0, 75]" 
                           width="450" />
                    
                    <!-- URL Box -->
                    <Rectangle width="450" height="100" color="0x333333FF" translation="[0, 105]">
                        <Label id="authUrlLabel" 
                               text="seedr.cc/pair" 
                               font="font:MediumBoldSystemFont" 
                               color="0xFFFFFFFF" 
                               translation="[15, 15]" 
                               width="420" 
                               height="70"
                               horizAlign="left" 
                               vertAlign="center"
                               wrap="true" />
                    </Rectangle>
                    
                    <!-- Step 2: Instructions and Code -->
                    <Label text="2. Follow the steps and when asked," 
                           font="font:SmallSystemFont" 
                           color="0xCCCCCCFF" 
                           translation="[0, 230]" 
                           width="450" 
                           wrap="true" />
                    
                    <Label text="type this code:" 
                           font="font:SmallSystemFont" 
                           color="0xCCCCCCFF" 
                           translation="[0, 255]" 
                           width="450" />
                    
                    <!-- Code Display -->
                    <Rectangle width="240" height="60" color="0x333333FF" translation="[105, 290]">
                        <Label id="userCodeLabel" 
                               text="XHWXV3BK" 
                               font="font:LargeBoldSystemFont" 
                               color="0x1DB954FF" 
                               translation="[10, 10]" 
                               width="220"
                               height="40"
                               horizAlign="center" 
                               vertAlign="center" />
                    </Rectangle>
                </Group>
            </Group>
            
            <!-- Timer and Status (at bottom of page) -->
            <Group id="statusSection" translation="[50, 590]">
                <!-- Timer Bar -->
                <Rectangle id="timerBarBg" width="950" height="6" color="0x333333FF" translation="[0, 0]" />
                <Rectangle id="timerBar" width="950" height="6" color="0x1DB954FF" translation="[0, 0]" />
                
                <!-- Status Text -->
                <Label id="statusLabel" 
                       text="Waiting for authorization..." 
                       font="font:SmallSystemFont" 
                       color="0x888888FF" 
                       translation="[0, 20]" 
                       horizAlign="left" />
                
                <!-- Timer Text -->
                <Label id="timerLabel" 
                       text="Expires in 29:37" 
                       font="font:SmallSystemFont" 
                       color="0xCCCCCCFF" 
                       translation="[850, 20]" 
                       horizAlign="right" />
                    </Group>
                    

        </Group>
        
        <!-- Success State Overlay -->
        <Rectangle id="successState" visible="false" translation="[0, 0]" width="1920" height="1080" color="0x000000FF" opacity="0.7">
            <!-- Success content group - will be positioned dynamically -->
            <Group id="successContent" translation="[660, 365]">
            <!-- Success card background -->
                <Rectangle width="600" height="350" color="0x1a1a1aFF" translation="[-300, -175]" opacity="0.98" />
                <Rectangle width="596" height="346" color="0x1DB95433" translation="[-298, -173]" />
                
                <!-- Success checkmark circle -->
                <Rectangle width="100" height="100" color="0x1DB954FF" translation="[-50, -130]" />
                
                <!-- Checkmark using simple shape -->
                <Label text="OK" 
                       font="font:LargeBoldSystemFont" 
                       color="0xFFFFFFFF" 
                       translation="[-50, -130]" 
                       width="100"
                       height="100"
                       horizAlign="center" 
                       vertAlign="center" />
            
            <!-- Success message -->
            <Label text="Successfully connected!" 
                   font="font:LargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                       translation="[-300, -10]" 
                       width="600"
                   horizAlign="center" />
            
            <Label text="Loading your media library..." 
                   font="font:MediumSystemFont" 
                   color="0xCCCCCCFF" 
                       translation="[-300, 35]" 
                       width="600"
                   horizAlign="center" />
        </Group>
        </Rectangle>
        
        <!-- Error State Overlay -->
        <Rectangle id="errorState" visible="false" translation="[0, 0]" width="1920" height="1080" color="0x000000FF" opacity="0.7">
            <!-- Error content group - will be positioned dynamically -->
            <Group id="errorContent" translation="[660, 380]">
            <!-- Error card background -->
                <Rectangle width="600" height="320" color="0x1a1a1aFF" translation="[-300, -160]" opacity="0.98" />
                <Rectangle width="596" height="316" color="0xFF333333" translation="[-298, -158]" />
                
                <!-- Error icon circle -->
                <Rectangle width="100" height="100" color="0xFF3333FF" translation="[-50, -120]" />
                
                <!-- Error icon using ! (more visible) -->
            <Label text="!" 
                   font="font:VeryLargeBoldSystemFont" 
                       color="0xFFFFFFFF" 
                       translation="[-50, -120]" 
                       width="100"
                       height="100"
                       horizAlign="center" 
                       vertAlign="center" />
            
            <!-- Error message -->
            <Label id="errorMessage" 
                   text="Connection failed" 
                   font="font:LargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                       translation="[-300, 0]" 
                       width="600"
                   horizAlign="center" />
            
            <Label text="Press OK to try again" 
                   font="font:MediumSystemFont" 
                   color="0xCCCCCCFF" 
                       translation="[-300, 45]" 
                       width="600"
                   horizAlign="center" />
        </Group>
        </Rectangle>
    </children>
</component>