<?xml version="1.0" encoding="UTF-8"?>

<component name="SubscriptionScreen" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/SubscriptionScreen.brs" />
    
    <interface>
        <!-- Input fields -->
        <field id="visible" type="boolean" value="false" />
        <field id="catalogData" type="assocarray" />
        <field id="purchasesData" type="assocarray" />
        <field id="currentSubscription" type="assocarray" />
        
        <!-- Output fields -->
        <field id="productSelected" type="string" />
        <field id="backPressed" type="boolean" alwaysNotify="true" />
    </interface>
    
    <children>
        <!-- Background -->
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x000000FF"
            opacity="0.95" />
        
        <!-- ========== USER INFO VIEW ========== -->
        <Group id="userInfoView" visible="true">
            <!-- Main container -->
            <Rectangle
                id="userInfoPanel"
                translation="[160, 100]"
                width="1600"
                height="880"
                color="0x1a1a1aFF">
                
                <!-- Border -->
                <Rectangle
                    width="1600"
                    height="4"
                    color="0x1DB954FF" />
                <Rectangle
                    translation="[0, 876]"
                    width="1600"
                    height="4"
                    color="0x1DB954FF" />
            </Rectangle>
            
            <!-- Header -->
            <Label
                id="userInfoHeader"
                translation="[200, 140]"
                width="1520"
                height="60"
                text="Account"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
                horizAlign="center"
                vertAlign="center" />
            
            <!-- User Email -->
            <Label
                id="userEmail"
                translation="[300, 220]"
                width="1320"
                height="40"
                text="Loading..."
                font="font:MediumSystemFont"
                color="0xCCCCCCFF"
                horizAlign="left"
                vertAlign="center" />
            
            <!-- Premium Status -->
            <Rectangle
                id="premiumBadge"
                translation="[300, 280]"
                width="200"
                height="50"
                color="0x1DB954FF">
                <Label
                    id="premiumStatusLabel"
                    width="200"
                    height="50"
                    text="Premium"
                    font="font:MediumBoldSystemFont"
                    color="0xFFFFFFFF"
                    horizAlign="center"
                    vertAlign="center" />
            </Rectangle>
            
            <!-- Storage Info -->
            <Label
                id="storageLabel"
                translation="[300, 360]"
                width="1320"
                height="40"
                text="Storage:"
                font="font:MediumBoldSystemFont"
                color="0xFFFFFFFF"
                horizAlign="left"
                vertAlign="center" />
            
            <Label
                id="storageUsed"
                translation="[300, 400]"
                width="1320"
                height="35"
                text="Used: 0 GB"
                font="font:MediumSystemFont"
                color="0xCCCCCCFF"
                horizAlign="left"
                vertAlign="center" />
            
            <Label
                id="storageLimit"
                translation="[300, 440]"
                width="1320"
                height="35"
                text="Total: 0 GB"
                font="font:MediumSystemFont"
                color="0xCCCCCCFF"
                horizAlign="left"
                vertAlign="center" />
            
            <!-- Storage Progress Bar -->
            <Rectangle
                id="storageBarBg"
                translation="[300, 490]"
                width="1000"
                height="20"
                color="0x333333FF">
                <Rectangle
                    id="storageBarFill"
                    width="0"
                    height="20"
                    color="0x1DB954FF" />
            </Rectangle>
            
            <!-- Features -->
            <Label
                id="featuresLabel"
                translation="[300, 540]"
                width="1320"
                height="40"
                text="Features:"
                font="font:MediumBoldSystemFont"
                color="0xFFFFFFFF"
                horizAlign="left"
                vertAlign="center" />
            
            <Label
                id="maxTorrents"
                translation="[300, 580]"
                width="1320"
                height="30"
                text="Max Torrents: 0"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
                horizAlign="left"
                vertAlign="center" />
            
            <Label
                id="activeTorrents"
                translation="[300, 615]"
                width="1320"
                height="30"
                text="Active Torrents: 0"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
                horizAlign="left"
                vertAlign="center" />
            
            <Label
                id="concurrentDownloads"
                translation="[300, 650]"
                width="1320"
                height="30"
                text="Concurrent Downloads: unlimited"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
                horizAlign="left"
                vertAlign="center" />
            
            <!-- Logout Button -->
            <Rectangle
                id="logoutButton"
                translation="[660, 750]"
                width="400"
                height="80"
                color="0xFF4444FF">
                <Label
                    id="logoutButtonText"
                    width="400"
                    height="80"
                    text="Logout"
                    font="font:LargeBoldSystemFont"
                    color="0xFFFFFFFF"
                    horizAlign="center"
                    vertAlign="center" />
            </Rectangle>
            
            <!-- Footer -->
            <Label
                id="userInfoFooter"
                translation="[200, 950]"
                width="1520"
                height="40"
                text="OK Logout • BACK Return"
                font="font:SmallSystemFont"
                color="0x888888FF"
                horizAlign="center"
                vertAlign="center" />
        </Group>
        
        
        <!-- Loading indicator -->
        <Label
            id="loadingLabel"
            translation="[200, 500]"
            width="1520"
            height="60"
            text="Loading..."
            font="font:MediumBoldSystemFont"
            color="0x1DB954FF"
            horizAlign="center"
            vertAlign="center"
            visible="false" />
    </children>
</component>
