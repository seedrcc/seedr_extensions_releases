<?xml version="1.0" encoding="utf-8" ?>
<!-- Stream URL Task Component -->

<component name="StreamUrlTask" extends="Task">

  <interface>
    <!-- Input fields -->
    <field id="fileId" type="string" />
    <field id="accessToken" type="string" />
    <field id="isAudio" type="boolean" value="false" />
    
    <!-- Output fields -->
    <field id="streamUrl" type="string" />
    <field id="error" type="string" />
  </interface>

  <script type="text/brightscript" uri="StreamUrlTask.brs" />

</component>
