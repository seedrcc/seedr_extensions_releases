<?xml version="1.0" encoding="UTF-8"?>
<component name="VideoItem" extends="Group">
    
    <interface>
        <field id="itemContent" type="node"/>
        <field id="focusPercent" type="float"/>
        <field id="progressPercent" type="float" alwaysnotify="true"/>
    </interface>
    
    <script type="text/brightscript" uri="pkg:/components/VideoItem.brs"/>

    <children>
        <!-- Main video thumbnail poster -->
        <Poster 
            id="itemPoster" 
            translation="[0, 0]" 
            width="300" 
            height="160"
            loadDisplayMode="scaleToFit"
            scaleRotateCenter="[150.0, 80.0]">

            <!-- Dark overlay mask that fades on focus -->
            <Rectangle 
                id="itemMask" 
                color="0x000000FF" 
                opacity="0.4" 
                width="300" 
                height="160" 
                scaleRotateCenter="[150.0, 80.0]" />
            
            <!-- Play button overlay - centered -->
            <Poster
                id="playButtonOverlay"
                translation="[125, 55]"
                width="50"
                height="50"
                uri="pkg:/images/button-img-show-white.png"
                loadDisplayMode="scaleToFit"
                scaleRotateCenter="[25.0, 25.0]" />
                
            <!-- Progress bar at bottom -->
            <VideoProgressBar 
                id="progressBar"
                translation="[0, 156]" 
                width="300"
                height="4"
                progressPercent="0"
            />
            
            <!-- Progress bar mask overlay -->
            <Rectangle 
                id="progressMask" 
                color="0x000000FF" 
                opacity="0.4" 
                width="300"
                height="4" 
                translation="[0, 156]"
                scaleRotateCenter="[150.0, 2.0]" 
            />

        </Poster>
        
        <!-- Video title below thumbnail -->
        <Label
            id="videoTitle"
            translation="[0, 165]"
            width="300"
            height="35"
            font="font:SmallSystemFont"
            color="0xFFFFFFFF"
            horizAlign="left"
            vertAlign="top"
            wrap="true"
            maxLines="2"
        />
        
    </children>
</component>
