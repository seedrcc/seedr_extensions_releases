<?xml version="1.0" encoding="utf-8" ?>
<component name="AudioPlayer" extends="Group">
    <interface>
        <field id="audioContent" type="assocarray" />
        <field id="fileName" type="string" />
        <field id="albumArt" type="string" />
        <field id="artist" type="string" value="Seedr" />
        <field id="album" type="string" value="My Files" />
        <field id="duration" type="integer" value="248" />
        <field id="isPlaying" type="boolean" value="true" />
        <field id="currentTime" type="integer" value="0" />
        <field id="onBackPressed" type="boolean" value="false" />
    </interface>

    <children>
        <!-- Background - Modern dark gradient -->
        <Rectangle id="background" width="1280" height="720" color="0x0A0A0AFF" />
        
        <!-- Gradient overlay for depth and modern look -->
        <Rectangle id="gradientOverlay" width="1280" height="720" color="0x1A1A2EFF" />
        
        <!-- Additional gradient layer for depth -->
        <Rectangle id="gradientLayer2" width="1280" height="720" color="0x16213EFF" />
        
        <!-- Header section with modern styling -->
        <Rectangle id="headerBackground" 
                   translation="[0, 0]" 
                   width="1280" 
                   height="80" 
                   color="0x00000040" />
        
        <Label id="nowPlayingLabel" 
               text="Now playing..." 
               translation="[60, 25]" 
               font="font:LargeSystemFont" 
               color="0xFFFFFFFF" />
        
        <Label id="trackCountLabel" 
               text="Track 1 / 1" 
               translation="[60, 50]" 
                   font="font:MediumSystemFont" 
               color="0xCCCCCCFF" />
        
        <!-- Time display (top right) with better styling -->
        <Label id="timeLabel" 
               text="12:55 PM" 
               translation="[1200, 25]" 
               font="font:LargeSystemFont" 
               color="0xFFFFFFFF" 
               horizAlign="right" />
        
        <!-- Large album art section with modern styling -->
            <Rectangle id="albumArtBackground" 
                   translation="[60, 120]" 
                   width="320" 
                   height="320" 
                   color="0x000000FF" />
        
        <!-- Shadow effect for album art -->
        <Rectangle id="albumArtShadow" 
                   translation="[65, 125]" 
                   width="320" 
                   height="320" 
                   color="0x00000080" />
            
            <Poster id="albumArtPoster" 
                translation="[60, 120]" 
                width="320" 
                height="320" 
                    visible="false" />
            
        <!-- Default large music icon when no album art - modern design -->
        <Group id="musicIconGroup" translation="[60, 120]">
            <!-- Large music note icon with modern styling -->
            <Rectangle translation="[110, 110]" width="100" height="100" color="0x2A2A2AFF" />
            <Label translation="[150, 150]" text="♫" font="font:VeryLargeSystemFont" color="0xFFFFFFFF" />
            </Group>
            
        <!-- Track information with improved typography and positioning -->
                <Label id="trackTitleLabel" 
               translation="[420, 180]" 
               font="font:VeryLargeSystemFont" 
                       color="0xFFFFFFFF" 
               width="800" />
                
                <Label id="artistLabel" 
               translation="[420, 240]" 
                       font="font:LargeSystemFont" 
                       color="0xCCCCCCFF" 
               width="800" />
                
                <Label id="albumLabel" 
               translation="[420, 280]" 
                       font="font:MediumSystemFont" 
                       color="0x999999FF" 
               width="800" />
        
        <!-- Duration display -->
        <Label id="durationLabel" 
               translation="[420, 320]" 
                       font="font:MediumSystemFont" 
               color="0x888888FF" 
               width="800" />
        
        
        <!-- Progress bar section with modern styling -->
            <Rectangle id="progressBackground" 
                   translation="[60, 580]" 
                   width="1160" 
                   height="6" 
                   color="0x333333FF" />
        
            <Rectangle id="progressFill" 
                   translation="[60, 580]" 
                       width="0" 
                   height="6" 
                   color="0x8A2BE2FF" />
        
        <!-- Enhanced border below progress bar for better visual separation -->
        <Rectangle id="progressBorder" 
                   translation="[60, 590]" 
                   width="1160" 
                   height="2" 
                   color="0x555555FF" />
        
        <!-- Additional subtle border for depth -->
        <Rectangle id="progressBorder2" 
                   translation="[60, 592]" 
                   width="1160" 
                   height="1" 
                   color="0x222222FF" />
        
        <!-- Time display - centered below progress with better styling -->
            <Label id="progressTimeLabel" 
               translation="[640, 610]" 
                   font="font:MediumSystemFont" 
                   color="0xFFFFFFFF" 
               text="00:00 / 04:08" 
                   horizAlign="center" />
        
        <!-- Enhanced border above control bar for better visual separation -->
        <Rectangle id="controlBarBorder" 
                   translation="[0, 635]" 
                   width="1280" 
                   height="3" 
                   color="0x666666FF" />
        
        <!-- Additional subtle border for depth -->
        <Rectangle id="controlBarBorder2" 
                   translation="[0, 638]" 
                   width="1280" 
                   height="1" 
                       color="0x333333FF" />
        
        <!-- Control bar with modern styling -->
        <Rectangle id="controlBarBackground" 
                   translation="[0, 640]" 
                   width="1280" 
                   height="80" 
                   color="0x00000060" />
        
        <!-- Control buttons with improved styling -->
        <Group id="controlButtonsGroup" translation="[500, 660]">
            <!-- Previous button -->
            <Rectangle id="prevButton" translation="[0, 0]" width="60" height="50" color="0x333333FF" />
            <Label id="prevLabel" translation="[15, 12]" text="⏮" font="font:LargeSystemFont" color="0xFFFFFFFF" />
            
            <!-- Play/Pause button -->
            <Rectangle id="playButton" translation="[80, 0]" width="60" height="50" color="0x8A2BE2FF" />
            <Label id="playLabel" translation="[95, 12]" text="⏸" font="font:LargeSystemFont" color="0xFFFFFFFF" />
            
            <!-- Next button -->
            <Rectangle id="nextButton" translation="[160, 0]" width="60" height="50" color="0x333333FF" />
            <Label id="nextLabel" translation="[175, 12]" text="⏭" font="font:LargeSystemFont" color="0xFFFFFFFF" />
        </Group>
        
        <!-- Right side controls with modern styling -->
        <Group id="rightControlsGroup" translation="[900, 660]">
            <!-- Shuffle button -->
            <Rectangle id="shuffleButton" translation="[0, 0]" width="50" height="50" color="0x333333FF" />
            <Label id="shuffleLabel" translation="[15, 12]" text="🔀" font="font:MediumSystemFont" color="0xFFFFFFFF" />
            
            <!-- Repeat button -->
            <Rectangle id="repeatButton" translation="[70, 0]" width="50" height="50" color="0x333333FF" />
            <Label id="repeatLabel" translation="[85, 12]" text="🔁" font="font:MediumSystemFont" color="0xFFFFFFFF" />
            
            <!-- Settings button -->
            <Rectangle id="settingsButton" translation="[140, 0]" width="50" height="50" color="0x333333FF" />
            <Label id="settingsLabel" translation="[155, 12]" text="⚙" font="font:MediumSystemFont" color="0xFFFFFFFF" />
        </Group>
        
    </children>
    
    <script type="text/brightscript" uri="AudioPlayer.brs" />
</component>
