<?xml version="1.0" encoding="utf-8" ?>
<component name="DocumentViewer" extends="Group">
    <interface>
        <field id="documentData" type="assocarray" alwaysnotify="true" />
        <field id="onBackPressed" type="boolean" value="false" />
    </interface>

    <script type="text/brightscript" uri="DocumentViewer.brs" />

    <children>
        <!-- Background -->
        <Rectangle 
            id="background"
            color="0x1A1A1AFF"
            width="1280"
            height="720" />

        <!-- Header -->
        <Group id="header" translation="[0, 0]">
            <Rectangle 
                id="headerBackground"
                color="0x2A2A2AFF"
                width="1280"
                height="80" />
            
            <Label
                id="headerTitle"
                text="Document Viewer"
                translation="[40, 20]"
                color="0x00ADEFFF"
                font="font:LargeSystemFont" />
            
            <Label
                id="headerSubtitle"
                text=""
                translation="[40, 50]"
                color="0xCCCCCCFF"
                font="font:MediumSystemFont"
                width="1200" />
        </Group>

        <!-- Main content area -->
        <Group id="contentArea" translation="[40, 120]">
            
            <!-- Document info -->
            <Group id="documentInfo" translation="[0, 0]">
                <Rectangle 
                    id="infoBackground"
                    color="0x333333FF"
                    width="1200"
                    height="200" />
                
                <!-- Document icon -->
                <Poster
                    id="documentIcon"
                    translation="[40, 40]"
                    width="120"
                    height="120"
                    uri="pkg:/images/document.png" />
                
                <!-- Document details -->
                <Group id="documentDetails" translation="[200, 40]">
                    <Label
                        id="documentTitle"
                        text=""
                        translation="[0, 0]"
                        color="0xFFFFFFFF"
                        font="font:LargeSystemFont"
                        width="960" />
                    
                    <Label
                        id="documentSize"
                        text=""
                        translation="[0, 40]"
                        color="0xCCCCCCFF"
                        font="font:MediumSystemFont"
                        width="960" />
                    
                    <Label
                        id="documentType"
                        text=""
                        translation="[0, 70]"
                        color="0xCCCCCCFF"
                        font="font:MediumSystemFont"
                        width="960" />
                    
                    <Label
                        id="documentDate"
                        text=""
                        translation="[0, 100]"
                        color="0xCCCCCCFF"
                        font="font:MediumSystemFont"
                        width="960" />
                </Group>
            </Group>

            <!-- Action buttons -->
            <Group id="actionButtons" translation="[0, 240]">
                <Rectangle 
                    id="actionsBackground"
                    color="0x333333FF"
                    width="1200"
                    height="120" />
                
                <Label
                    id="actionsTitle"
                    text="Available Actions:"
                    translation="[40, 20]"
                    color="0x00ADEFFF"
                    font="font:MediumBoldSystemFont" />
                
                <Label
                    id="downloadAction"
                    text="• Download: Press OK to get download link"
                    translation="[40, 50]"
                    color="0xFFFFFFFF"
                    font="font:MediumSystemFont" />
                
                <Label
                    id="backAction"
                    text="• Back: Return to file browser"
                    translation="[40, 80]"
                    color="0xFFFFFFFF"
                    font="font:MediumSystemFont" />
            </Group>

            <!-- Preview area (for future enhancement) -->
            <Group id="previewArea" translation="[0, 400]">
                <Rectangle 
                    id="previewBackground"
                    color="0x333333FF"
                    width="1200"
                    height="160" />
                
                <Label
                    id="previewTitle"
                    text="Document Preview"
                    translation="[40, 20]"
                    color="0x00ADEFFF"
                    font="font:MediumBoldSystemFont" />
                
                <Label
                    id="previewMessage"
                    text="Document preview is not available on Roku. Use the download option to access the file on another device."
                    translation="[40, 50]"
                    color="0xCCCCCCFF"
                    font="font:MediumSystemFont"
                    width="1120"
                    wrap="true" />
            </Group>
        </Group>

        <!-- Download dialog -->
        <Group id="downloadDialog" translation="[340, 200]" visible="false">
            <Rectangle 
                id="dialogBackground"
                color="0x000000DD"
                width="600"
                height="320" />
            
            <Rectangle 
                id="dialogBorder"
                color="0x00ADEFFF"
                width="600"
                height="2" />
            <Rectangle 
                id="dialogBorder2"
                color="0x00ADEFFF"
                width="600"
                height="2"
                translation="[0, 318]" />
            <Rectangle 
                id="dialogBorder3"
                color="0x00ADEFFF"
                width="2"
                height="320" />
            <Rectangle 
                id="dialogBorder4"
                color="0x00ADEFFF"
                width="2"
                height="320"
                translation="[598, 0]" />
            
            <Label
                id="dialogTitle"
                text="Download Link"
                translation="[40, 30]"
                color="0x00ADEFFF"
                font="font:LargeBoldSystemFont" />
            
            <Label
                id="dialogMessage"
                text="Getting download link..."
                translation="[40, 80]"
                color="0xFFFFFFFF"
                font="font:MediumSystemFont"
                width="520"
                wrap="true" />
            
            <Label
                id="dialogHint"
                text="Press Back to close"
                translation="[40, 260]"
                color="0xCCCCCCFF"
                font="font:SmallSystemFont" />
        </Group>

        <!-- Error overlay -->
        <Group id="errorOverlay" translation="[340, 250]" visible="false">
            <Rectangle 
                id="errorBackground"
                color="0x800000FF"
                width="600"
                height="220" />
            
            <Label
                id="errorTitle"
                text="Error"
                translation="[40, 30]"
                color="0xFFFFFFFF"
                font="font:LargeBoldSystemFont" />
            
            <Label
                id="errorMessage"
                text=""
                translation="[40, 80]"
                color="0xFFFFFFFF"
                font="font:MediumSystemFont"
                width="520"
                wrap="true" />
            
            <Label
                id="errorHint"
                text="Press Back to return"
                translation="[40, 160]"
                color="0xCCCCCCFF"
                font="font:SmallSystemFont" />
        </Group>
    </children>
</component>
