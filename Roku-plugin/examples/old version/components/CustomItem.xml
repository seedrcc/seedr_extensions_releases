<?xml version="1.0" encoding="utf-8" ?>
<!-- Custom Item Component for Hero Grid -->

<component name="CustomItem" extends="Group">

  <children>
    <!-- Item background/border -->
    <Rectangle 
      id="itemBackground"
      width="375" 
      height="197" 
      color="0x262626FF" />
    
    <!-- Focus indicator -->
    <Rectangle 
      id="focusIndicator"
      width="375" 
      height="197" 
      color="0x0066CCFF" 
      opacity="0" />
    
    <!-- Item poster/thumbnail -->
    <Poster 
      id="itemPoster"
      width="365" 
      height="140"
      translation="[5, 5]"
      loadDisplayMode="scaleToFill"
      failedBitmapUri="pkg:/images/icon_focus_hd.png" />
    
    <!-- Item overlay for text -->
    <Rectangle 
      id="textOverlay"
      width="365" 
      height="47"
      translation="[5, 145]"
      color="0x000000CC" />
    
    <!-- Item title -->
    <Label 
      id="itemTitle"
      width="355" 
      height="37"
      translation="[10, 150]"
      font="font:SmallBoldSystemFont" 
      color="0xFFFFFFFF"
      horizAlign="left"
      vertAlign="center"
      wrap="true"
      maxLines="2" />
    
    <!-- Item type indicator -->
    <Rectangle 
      id="typeIndicator"
      width="40" 
      height="20"
      translation="[10, 10]"
      color="0x0066CCFF" />
    
    <Label 
      id="typeLabel"
      width="40" 
      height="20"
      translation="[10, 10]"
      font="font:SmallSystemFont" 
      color="0xFFFFFFFF"
      horizAlign="center"
      vertAlign="center"
      text="" />
  </children>

  <interface>
    <field id="itemContent" type="node" onChange="itemContentChanged" />
    <field id="focusPercent" type="float" onChange="focusPercentChanged" />
  </interface>

  <script type="text/brightscript" uri="CustomItem.brs" />

</component>
