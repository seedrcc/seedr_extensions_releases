<?xml version="1.0" encoding="utf-8" ?>
<!-- Audio Task Component for Audio Playback -->

<component name="AudioTask" extends="Task">

  <interface>
    <!-- Input fields -->
    <field id="audioUrl" type="string" />
    <field id="command" type="string" />  <!-- play, pause, resume, stop, seek -->
    <field id="seekPosition" type="integer" />
    
    <!-- Output fields -->
    <field id="isPlaying" type="boolean" value="false" />
    <field id="currentPosition" type="integer" value="0" />
    <field id="duration" type="integer" value="0" />
    <field id="error" type="string" />
  </interface>

  <script type="text/brightscript" uri="AudioTask.brs" />

</component>
