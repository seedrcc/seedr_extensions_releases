<?xml version="1.0" encoding="UTF-8"?>
<!--********** Seedr for Roku - File Grid Screen **********-->

<component name="GridScreen" extends="Group">
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/api.brs" />
    <script type="text/brightscript" uri="pkg:/source/auth.brs" />
    <script type="text/brightscript" uri="GridScreen.brs" />
    
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="980" color="0x1a1a1aFF" />
        
        <!-- Breadcrumb -->
        <Label id="breadcrumbLabel" text="Home" 
               font="font:MediumSystemFont" 
               color="0xCCCCCCFF" 
               translation="[50, 50]" />
        
        <!-- File Grid -->
        <RowList id="fileGrid" 
                 translation="[50, 100]" 
                 itemComponentName="FileItem"
                 rowItemSize="[400, 300]"
                 rowHeights="[300]"
                 itemSpacing="[20, 20]"
                 width="1820"
                 height="800" />
        
        <!-- Empty State -->
        <Group id="emptyState" visible="false" translation="[960, 400]">
            <Label text="No files found" 
                   font="font:LargeBoldSystemFont" 
                   color="0x888888FF" 
                   horizAlign="center" />
        </Group>
    </children>
</component>
