<?xml version="1.0" encoding="UTF-8"?>
<!--********** Seedr for Roku - Netflix-Style Authentication Screen **********-->

<component name="AuthScreen" extends="Group">
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/api.brs" />
    <script type="text/brightscript" uri="pkg:/source/auth.brs" />
    <script type="text/brightscript" uri="AuthScreen.brs" />
    
    <interface>
        <field id="authCheck" type="integer" />
    </interface>
    
    <children>
        <!-- Netflix-style gradient background -->
        <Rectangle id="background" width="1280" height="720" color="0x0A0A0AFF" />
        <Rectangle id="gradientOverlay" width="1280" height="720" color="0x1A1A2EFF" opacity="0.8" />
        
        <!-- Simple Seedr Logo -->
        <Label text="Seedr" 
               font="font:VeryLargeBoldSystemFont" 
               color="0x0066CCFF" 
               translation="[100, 80]" 
               horizAlign="left" />
        
        <Label text="Not authenticated" 
               font="font:MediumSystemFont" 
               color="0x999999FF" 
               translation="[1180, 80]" 
               horizAlign="right" />
        
        <!-- Simple Connecting Dialog -->
        <Group id="connectingDialog" visible="true" translation="[640, 360]">
            <!-- Simple card -->
            <Rectangle width="600" height="200" color="0x1E1E2EFF" translation="[-300, -100]" />
            
            <!-- Title -->
            <Label text="Connecting to Seedr..." 
                   font="font:LargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[0, -40]" 
                   horizAlign="center" />
            
            <!-- Status -->
            <Label id="connectingStatus" text="Please wait..." 
                   font="font:MediumSystemFont" 
                   color="0x0066CCFF" 
                   translation="[0, 0]" 
                   horizAlign="center" />
            
            <!-- Progress -->
            <Label id="connectingProgress" text="Setting up authentication..." 
                   font="font:SmallSystemFont" 
                   color="0xAAAABBFF" 
                   translation="[0, 40]" 
                   horizAlign="center" />
        </Group>
        
        <!-- Clean Authentication Dialog -->
        <Group id="authDialog" visible="false" translation="[640, 360]">
            <!-- Simple centered card -->
            <Rectangle width="1100" height="400" color="0x1E1E2EFF" translation="[-550, -200]" />
            
            <!-- Main title -->
            <Label text="Connect to Seedr" 
                   font="font:VeryLargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[0, -140]" 
                   horizAlign="center" />
            
            <!-- Simple instruction -->
            <Label text="Visit this URL to authorize:" 
                   font="font:LargeBoldSystemFont" 
                   color="0xCCCCCCFF" 
                   translation="[0, -80]" 
                   horizAlign="center" />
            
            <!-- Clean URL display box -->
            <Rectangle width="1000" height="60" color="0x0066CCFF" translation="[-500, -30]" />
            <Label id="authUrlLabel" text="" 
                   font="font:LargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[0, 0]" 
                   horizAlign="center"
                   width="980" />
            
            <!-- Bottom instruction -->
            <Label text="The page will confirm when complete" 
                   font="font:MediumSystemFont" 
                   color="0xAAAABBFF" 
                   translation="[0, 60]" 
                   horizAlign="center" />
            
            <!-- Timer at bottom -->
            <Group translation="[0, 120]">
                <Label id="timerLabel" text="" 
                       font="font:MediumBoldSystemFont" 
                       color="0x0066CCFF" 
                       translation="[0, 0]" 
                       horizAlign="center" />
                <Label id="statusLabel" text="Waiting for authorization..." 
                       font="font:SmallSystemFont" 
                       color="0x999999FF" 
                       translation="[0, 30]" 
                       horizAlign="center" />
            </Group>
        </Group>
        
        <!-- Simple Connected Dialog -->
        <Group id="connectedDialog" visible="false" translation="[640, 360]">
            <!-- Success card -->
            <Rectangle width="600" height="250" color="0x1E1E2EFF" translation="[-300, -125]" />
            
            <!-- Success message -->
            <Label text="✓ Connected Successfully!" 
                   font="font:VeryLargeBoldSystemFont" 
                   color="0x00CC88FF" 
                   translation="[0, -60]" 
                   horizAlign="center" />
            
            <Label text="Welcome to Seedr" 
                   font="font:LargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[0, -10]" 
                   horizAlign="center" />
            
            <Label text="Loading your media library..." 
                   font="font:MediumSystemFont" 
                   color="0x0066CCFF" 
                   translation="[0, 40]" 
                   horizAlign="center" />
        </Group>
    </children>
</component>
