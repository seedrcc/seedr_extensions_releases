<?xml version="1.0" encoding="utf-8" ?>
<!-- Loading Indicator Component -->

<component name="LoadingIndicator" extends="Group">

  <children>
    <!-- Background overlay -->
    <Rectangle
      id="backgroundRect"
      width="1920"
      height="1080"
      color="0x000000"
      opacity="0.7" />

    <!-- Loading content group -->
    <Group id="loadingGroup" translation="[960, 540]">
      <!-- Loading spinner -->
      <Poster
        id="spinner"
        width="100"
        height="100"
        translation="[-50, -80]"
        uri="pkg:/images/loader.png" />
      
      <!-- Loading text -->
      <Label
        id="loadingText"
        text="Loading..."
        font="font:MediumBoldSystemFont"
        color="0xFFFFFFFF"
        translation="[0, 20]"
        horizAlign="center"
        vertAlign="center" />
    </Group>
  </children>

  <interface>
    <field id="imageUri" type="string" value="pkg:/images/loader.png" />
    <field id="clockwise" type="boolean" value="true" />
    <field id="spinInterval" type="float" value="2.0" />
    <field id="fadeInterval" type="float" value="0.5" />
    <field id="spacing" type="integer" value="20" />
    <field id="imageWidth" type="integer" value="100" />
    <field id="text" type="string" value="Loading..." />
    <field id="textPadding" type="integer" value="10" />
    <field id="font" type="string" value="font:MediumBoldSystemFont" />
    <field id="backgroundColor" type="string" value="0x000000" />
    <field id="backgroundOpacity" type="float" value="0.7" />
    <field id="centered" type="boolean" value="true" />
    <field id="control" type="string" />
  </interface>

  <script type="text/brightscript" uri="LoadingIndicator.brs" />

</component>
