<?xml version="1.0" encoding="UTF-8"?>
<component name="SeedrAudioPlayer" extends="Group" xsi:noNamespaceSchemaLocation="https://devtools.web.roku.com/schema/RokuSceneGraph.xsd">
	<interface>
	
    	<field id = "itemContent" type = "node" alwaysnotify = "true"/>
    	<field id = "audioControl" type = "string" alwaysnotify = "true" alias = "audio.control"/>
    	<field id = "audioState" type = "string" alwaysnotify = "true" alias = "audio.state"/>
    	<field id = "resumeStatePoster" type = "string" alwaysnotify = "true" alias = "itemPlayStatePoster.uri"/>
    	<field id = "onBackPressed" type = "boolean" value = "false" />
    	<field id = "playNextFile" type = "assocarray" alwaysnotify = "true" />
    	<field id = "setCurrentFolderFiles" type = "assocarray" alwaysnotify = "true" />
    	<field id = "globalAudioCommand" type = "string" alwaysnotify = "true" />
    	<field id = "isGloballyPlaying" type = "boolean" value = "false" alwaysnotify = "true" />
    	<field id = "currentTrackInfo" type = "assocarray" alwaysnotify = "true" />
    	
    </interface>	
	<script type="text/brightscript" uri="pkg:/components/SeedrAudioPlayer.brs"/>
	
	<children>
	<Group id = "audioGroup">
			<Poster
				id = "backgroundPoster"
				uri = "pkg:/images/playerBackground.jpg"
				width = "600"
				height = "600"
				translation = "[0, 0]" 
			/>
			
		<Group id = "itemInfoGroup" translation = "[100, 40]" >		
			
			<Poster
				id = "itemPoster"
				uri = "pkg:/images/audio5.png"
				width = "400"
				height = "450"
				loadDisplayMode = "scaleToZoom"
				blendColor = "0x807a7b"	
				
			/>		
						
			<Animation id="authorAnimation"
				duration="34"
				repeat="true"
				easeFunction="linear" >
			</Animation>
	
			<Animation id="albumAnimation"
				duration="34"
				repeat="true"
				easeFunction="linear" >
			</Animation>
	
			<Animation id="songAnimation"
				duration="34"
				repeat="true"
				easeFunction="linear" >
			</Animation>				
			
				
		<Group id = "itemLabelGroup" clippingRect = "[0, 0, 395, 500]" >	
			
			<Group id = "itemAuthorGroup" translation = "[5, 300]">			
				<Label
					id="itemAuthor"
					font="font:MediumBoldSystemFont"
					horizAlign = "left"
					enableRenderTracking = "true"
					color = "0xFFFFFFFF"
				/>
			</Group>
			
			<Group id = "itemAlbumInfoGroup" translation = "[5, 350]">
				<Label
					id="itemAlbumInfo"
					height="44"
					width="0"
					font="font:SmallestSystemFont"
					horizAlign = "left"
					enableRenderTracking = "true"
					color = "0xCCCCCCFF"
				/>		
			</Group>
			
			<Group id = "itemSongGroup" translation = "[5, 400]">
				<Label
					id="itemSongName"
					height="44"
					width="0"
					font="font:SmallBoldSystemFont"
					horizAlign = "left"	
					enableRenderTracking = "true"
					color = "0xFFFFFFFF"
				/>	
			</Group>	
			
				<Poster
					id = "itemPlayStatePoster"
					width = "48"
					height = "48"
					blendColor = "0xf4f07c"
					uri = "pkg:/images/button_play.png"					
				/>
				
			<Label
					id = "itemRepeat"
					translation = "[0, 50]"
					text = "Repeat is OFF"
					color = "0xFFFFFFFF"
				/>		
				
			</Group>
			
		</Group>
			
		<Group id = "playerInfoGroup" translation = "[100, 490]">
			<Rectangle
				id = "backgroundInfoPoster"
				color = "0x1A1A1A"
				width = "400"
				height = "60"
				 
			/>
			
			<ProgressBar 
	        	id = "progressBar"
	        	translation = "[6, 30]"
	        	clippingRect = "[0, 0, 388, 6]"			
			/>
			
			
			<Label
				id="itemCurPosition"
				height="44"
				width="0"
				font="font:SmallestSystemFont"
				translation ="[5,2]"
				color = "0xFFFFFFFF"
				
			/>			
			
			<Label
				id="itemLenght"
				height="44"
				width="0"
				font="font:SmallestSystemFont"
				translation ="[312,2]"
				color = "0xFFFFFFFF"
			/>		
		
		</Group>
		
		<Timer
			id="timer"
			repeat="false"
			duration="1"
		/>
		<Poster
			id = "itemFramePoster"
			uri = "pkg:/images/item-focus.8.png"
			width = "420"
			height = "530"
			translation = "[90, 30]"
			visible = "false"				
		/>			
	</Group>	
	<Audio id = "audio"/>
</children>
	

</component>
