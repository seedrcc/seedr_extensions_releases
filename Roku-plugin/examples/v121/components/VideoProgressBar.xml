<?xml version="1.0" encoding="UTF-8"?>
<component name="VideoProgressBar" extends="Group" xsi:noNamespaceSchemaLocation="https://devtools.web.roku.com/schema/RokuSceneGraph.xsd">

    <interface>
        <field id="color" type="string" alwaysnotify="true" />
        <field id="width" type="float" alwaysnotify="true" />
        <field id="height" type="float" alwaysnotify="true" />
        <field id="progressPercent" type="float" alwaysnotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/VideoProgressBar.brs"/>

    <children>
        <!-- Background bar -->
        <Rectangle
            id="progressBackground"
            color="0x333333FF"
            height="4"
        />
        
        <!-- Progress fill -->
        <Rectangle
            id="progressFill"
            color="0x8A2BE2FF"
            height="4"
        />
    </children>

</component>
