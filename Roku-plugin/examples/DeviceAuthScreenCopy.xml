<?xml version="1.0" encoding="UTF-8"?>
<!--********** Seedr for Roku - Device Authorization Screen **********-->

<component name="DeviceAuthScreen" extends="Group">
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/api.brs" />
    <script type="text/brightscript" uri="pkg:/source/auth.brs" />
    <script type="text/brightscript" uri="DeviceAuthScreen.brs" />
    
    <interface>
        <field id="authComplete" type="boolean" />
        <field id="backPressed" type="boolean" alwaysNotify="true" />
    </interface>
    
    <children>
        <!-- Netflix-style background -->
        <Rectangle id="background" width="1280" height="720" color="0x000000FF" />
        
        <!-- Background image placeholder (dark with subtle pattern) -->
        <Rectangle width="1280" height="720" color="0x141414FF" />
        <Rectangle width="1280" height="720" color="0x1F1F1FFF" opacity="0.8" />
        
        <!-- Gradient overlay for text readability -->
        <Rectangle width="1280" height="720" color="0x000000FF" opacity="0.4" />
        
        <!-- SEEDR Logo (Netflix-style) -->
        <Label text="SEEDR" 
               font="font:VeryLargeBoldSystemFont" 
               color="0xE50914FF" 
               translation="[34, 20]" 
               horizAlign="left" />
        
        <!-- Connecting State -->
        <Group id="connectingState" visible="true" translation="[640, 360]">
            <!-- Card background -->
            <Rectangle width="600" height="300" color="0x1A1A1AFF" opacity="0.95" translation="[-300, -150]" />
            <Rectangle width="596" height="296" color="0x333333FF" opacity="0.3" translation="[-298, -148]" />
            
            <!-- Title -->
            <Label text="Connecting to Seedr..." 
                   font="font:LargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[0, -80]" 
                   horizAlign="center" />
            
            <!-- Status -->
            <Label id="connectingStatus" text="Please wait..." 
                   font="font:MediumSystemFont" 
                   color="0xE50914FF" 
                   translation="[0, -20]" 
                   horizAlign="center" />
            
            <!-- Progress -->
            <Label id="connectingProgress" text="Setting up authentication..." 
                   font="font:SmallSystemFont" 
                   color="0xCCCCCCFF" 
                   translation="[0, 20]" 
                   horizAlign="center" />
        </Group>
        
        <!-- Device Authorization State - Full Screen Layout -->
        <Group id="authState" visible="false" translation="[0, 0]">
            <!-- Full screen background -->
            <Rectangle width="1280" height="720" color="0x1A1A1AFF" opacity="0.95" />
            <Rectangle width="1280" height="720" color="0x333333FF" opacity="0.3" />
            
            <!-- Title -->
            <Label text="Visit this URL on your phone or computer:" 
                   font="font:LargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[50, 80]" 
                   horizAlign="left"
                   width="1180" />
            
            <!-- URL box - Full width -->
            <Rectangle width="1180" height="80" color="0x333333FF" translation="[50, 140]" />
            <Label id="authUrlLabel" text="" 
                   font="font:MediumBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[70, 180]" 
                   horizAlign="left"
                   width="1140" />
            
            <!-- Instruction -->
            <Label text="The page will confirm when authorization is complete" 
                   font="font:MediumSystemFont" 
                   color="0xCCCCCCFF" 
                   translation="[50, 260]" 
                   horizAlign="left"
                   width="1180" />
            
            <!-- Timer - Upper left position -->
            <Rectangle width="600" height="50" color="0xE50914FF" translation="[50, 320]" />
            <Label id="timerLabel" text="" 
                   font="font:MediumBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[70, 345]" 
                   horizAlign="left" />
            
            <!-- Status -->
            <Label id="statusLabel" text="Waiting for authorization..." 
                   font="font:SmallSystemFont" 
                   color="0xCCCCCCFF" 
                   translation="[50, 400]" 
                   horizAlign="left" />
                   
            <!-- Back instruction -->
            <Label text="Press BACK to return to main screen" 
                   font="font:SmallSystemFont" 
                   color="0x888888FF" 
                   translation="[50, 450]" 
                   horizAlign="left" />
        </Group>
        
        <!-- Success State -->
        <Group id="successState" visible="false" translation="[640, 360]">
            <!-- Success card -->
            <Rectangle width="600" height="350" color="0x1A1A1AFF" opacity="0.95" translation="[-300, -175]" />
            <Rectangle width="596" height="346" color="0x333333FF" opacity="0.3" translation="[-298, -173]" />
            
            <!-- Success icon -->
            <Rectangle width="80" height="80" color="0x00CC88FF" translation="[-40, -100]" />
            <Label text="✓" 
                   font="font:VeryLargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[0, -60]" 
                   horizAlign="center" />
            
            <!-- Success message -->
            <Label text="Welcome to Seedr!" 
                   font="font:LargeBoldSystemFont" 
                   color="0xFFFFFFFF" 
                   translation="[0, 0]" 
                   horizAlign="center" />
            
            <Label text="Your device has been authorized successfully" 
                   font="font:MediumSystemFont" 
                   color="0xCCCCCCFF" 
                   translation="[0, 40]" 
                   horizAlign="center"
                   width="550" />
            
            <!-- Loading -->
            <Label text="Loading your media library..." 
                   font="font:MediumSystemFont" 
                   color="0xE50914FF" 
                   translation="[0, 100]" 
                   horizAlign="center" />
        </Group>
    </children>
</component>

